default_platform(:ios)

platform :ios do
  desc "Build and upload directly to TestFlight on every push"
  lane :deploy_testflight do
    
    # 1. Standard CI initialization for headless keychain behavior
    setup_ci
    
    # 2. Fetch your pre-existing profiles from your private Git repo
    match(
      type: "appstore",
      readonly: true
    )

    # 3. Configure manual signing ONLY for the main app target (protects Swift Packages)
    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: "SU5Z39MX2P",
      bundle_identifier: "com.blaster.fpil",
      profile_name: "AppStoreFPIL2025",
      code_sign_identity: "Apple Distribution",
      targets: ["FPIL"]
    )
    
    # 5. Force slow cloud-runner stability variables
    ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] = "120"
    ENV["FASTLANE_XCODEBUILD_SETTINGS_RETRIES"] = "5"
    
    # 6. Build and package the application cleanly
    build_app(
      scheme: "FPIL",
      workspace: "FPIL.xcworkspace",
      export_method: "app-store",
      
      # Step A: Controls the compilation step (stops Swift Packages from screaming)
      xcargs: "CODE_SIGNING_ALLOWED=YES CODE_SIGNING_REQUIRED=YES 'CODE_SIGNING_ALLOWED[sdk=iphoneos*][type=com.apple.product-type.bundle]'=NO CODE_SIGN_IDENTITY=\"Apple Distribution\" DEVELOPMENT_TEAM=\"SU5Z39MX2P\"",
      
      # Step B: Forces the exporter to keep your certificate settings intact
      export_xcargs: "CODE_SIGN_IDENTITY=\"Apple Distribution\" DEVELOPMENT_TEAM=\"SU5Z39MX2P\"",
      
      export_options: {
        method: "app-store-connect",
        signingStyle: "manual",
        teamID: "SU5Z39MX2P",
        provisioningProfiles: {
          "com.blaster.fpil" => "AppStoreFPIL2025"
        }
      }
    )

    # 7. Upload the built binary straight into TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end
end