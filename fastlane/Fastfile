default_platform(:ios)

platform :ios do
  desc "Build and upload directly to TestFlight on every push"
  lane :deploy_testflight do
    
    # 1. Initialize CI environment for headless keychain access
    setup_ci
    
    # 2. Fetch your pre-existing profiles from your private Git repo
    match(
      type: "appstore",
      readonly: true
    )

    UI.message("Scrubbing project configuration file for legacy code signing identities...")
    project_path = "FPIL.xcodeproj/project.pbxproj"
    if File.exist?(project_path)
      file_contents = File.read(project_path)
      
      # 1. Replace legacy identity names with Apple Distribution
      updated_contents = file_contents.gsub("iOS Distribution", "Apple Distribution")
                                      .gsub("iPhone Distribution", "Apple Distribution")
      
      # 2. Enforce new Team ID across all configuration blocks
      updated_contents = updated_contents.gsub(/DEVELOPMENT_TEAM = [A-Z0-9]+;/, "DEVELOPMENT_TEAM = 8R2YXVH749;")
      
      File.open(project_path, "w") { |file| file.puts updated_contents }
      UI.success("Successfully updated project settings to Apple Distribution!")
    end

    # 4. Configure manual signing ONLY for the main app target (protects Swift Packages)
    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: "8R2YXVH749",
      bundle_identifier: "com.lmtech.fpil",
      profile_name: "fpil_store",
      code_sign_identity: "Apple Distribution",
      targets: ["FPIL"]
    )
    
    # 6. Force slow cloud-runner stability variables
    ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] = "120"
    ENV["FASTLANE_XCODEBUILD_SETTINGS_RETRIES"] = "5"
    
    # 7. Build and package the application cleanly
    build_app(
      scheme: "FPIL",
      workspace: "FPIL.xcworkspace",
      export_method: "app-store",
      
      xcargs: "CODE_SIGNING_ALLOWED=YES CODE_SIGNING_REQUIRED=YES 'CODE_SIGNING_ALLOWED[sdk=iphoneos*][type=com.apple.product-type.bundle]'=NO CODE_SIGN_IDENTITY=\"Apple Distribution\" DEVELOPMENT_TEAM=\"8R2YXVH749\"",
      
      export_options: {
        method: "app-store-connect",
        signingStyle: "manual",
        teamID: "8R2YXVH749",
        signingCertificate: "Apple Distribution", # Forces exportArchive to search strictly for Apple Distribution
        provisioningProfiles: {
          "com.lmtech.fpil" => "fpil_store"
        }
      }
    )

    # 8. Upload the built binary straight into TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end
end