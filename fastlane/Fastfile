default_platform(:ios)

platform :ios do
  desc "Build and upload directly to TestFlight on every push"
  lane :deploy_testflight do
    
    # 1. Standard CI initialization for headless keychain behavior
    setup_ci
    
    # 2. Fetch your pre-existing profiles from your private Git repo
    match(
      type: "appstore",
      readonly: true
    )

    # 3. Configure manual signing ONLY for the main app target (protects Swift Packages)
    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: "SU5Z39MX2P",
      bundle_identifier: "com.blaster.fpil",
      profile_name: "AppStoreFPIL2025",
      code_sign_identity: "Apple Distribution",
      targets: ["FPIL"]
    )
    
    # 4. FORCEFUL PROJECT blue-print patch:
    # This edits the underlying pbxproj text structure to completely delete 
    # any residual "iOS Distribution" hardcodings and swap them to "Apple Distribution".
    UI.message("Patching project configuration file structure...")
    project_path = "FPIL.xcodeproj/project.pbxproj"
    if File.exist?(project_path)
      file_contents = File.read(project_path)
      # Replaces the old identity keys with the modern profile standard
      updated_contents = file_contents.gsub('"CODE_SIGN_IDENTITY[sdk=iphoneos*]" = "iOS Distribution";', '"CODE_SIGN_IDENTITY[sdk=iphoneos*]" = "Apple Distribution";')
      updated_contents = updated_contents.gsub('CODE_SIGN_IDENTITY = "iOS Distribution";', 'CODE_SIGN_IDENTITY = "Apple Distribution";')
      File.open(project_path, "w") { |file| file.puts updated_contents }
      UI.success("Successfully rewritten build settings signature structure inside project file!")
    else
      UI.error("Could not locate project file path to patch configuration.")
    end
    
    # 6. FORCE the timeout parameters directly into the sub-shell thread 
    ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] = "120"
    ENV["FASTLANE_XCODEBUILD_SETTINGS_RETRIES"] = "5"
    
    # 7. Build your app cleanly
    build_app(
      scheme: "FPIL",
      workspace: "FPIL.xcworkspace",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: "SU5Z39MX2P",
        provisioningProfiles: {
          "com.blaster.fpil" => "AppStoreFPIL2025"
        }
      }
    )

    # 8. Upload the built binary straight into TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end
end