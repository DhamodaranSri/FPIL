default_platform(:ios)

platform :ios do
  desc "Build and upload directly to TestFlight on every push"
  lane :deploy_testflight do
    
    # 1. Standard CI initialization for headless keychain behavior
    setup_ci
    
    # 2. Fetch your pre-existing profiles from your private Git repo
    match(
      type: "appstore",
      readonly: true
    )

    # 3. Configure manual signing ONLY for the main app target (protects Swift Packages)
    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: "SU5Z39MX2P",
      bundle_identifier: "com.blaster.fpil",
      profile_name: "AppStoreFPIL2025",
      code_sign_identity: "Apple Distribution",
      targets: ["FPIL"]
    )
    
    # 5. FORCE the timeout parameters directly into the sub-shell thread 
    ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] = "120"
    ENV["FASTLANE_XCODEBUILD_SETTINGS_RETRIES"] = "5"
    
    # CREATE A DYNAMIC TARGET OVERRIDE FILE:
    # This forces Xcode to look for "Apple Distribution" and leaves 
    # the external Swift bundles cleanly managed.
    File.write("temp_signing.xcconfig", <<~XCCONFIG
      CODE_SIGN_IDENTITY = Apple Distribution
      CODE_SIGN_IDENTITY[sdk=iphoneos*] = Apple Distribution
      CODE_SIGNING_ALLOWED[sdk=iphoneos*][type=com.apple.product-type.bundle] = NO
    XCCONFIG
    )
    
    # 6. Build your app cleanly using the custom configuration file
    build_app(
      scheme: "FPIL",
      workspace: "FPIL.xcworkspace",
      export_method: "app-store",
      
      # Tell Fastlane to load our custom configuration file
      xcconfig: "temp_signing.xcconfig",
      
      export_options: {
        method: "app-store-connect",
        signingStyle: "manual",
        teamID: "SU5Z39MX2P",
        provisioningProfiles: {
          "com.blaster.fpil" => "AppStoreFPIL2025"
        }
      }
    )

    # Clean up the temporary file after the build completes
    File.delete("temp_signing.xcconfig") if File.exist?("temp_signing.xcconfig")

    # 7. Upload the built binary straight into TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end
end