default_platform(:ios)

platform :ios do
  desc "Build and upload directly to TestFlight on every push"
  lane :deploy_testflight do
    
    # 1. Fetch your pre-existing profiles from your private Git repo
    match(
      type: "appstore",
      readonly: true
    )
    
    # 3. Build your app with explicit export options mapping
    build_app(
      scheme: "FPIL",
      workspace: "FPIL.xcworkspace",
      export_method: "app-store",
      # FORCE Xcode to use the exact matching identities we just unlocked
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: "SU5Z39MX2P",
        provisioningProfiles: {
          "com.blaster.fpil" => "AppStoreFPIL2025" # Mapped from your match log output
        }
      }
    )

    # 5. Upload the built binary straight into TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true # Saves runner time by not waiting for Apple processing
    )
  end
end