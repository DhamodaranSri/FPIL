default_platform(:ios)

platform :ios do
  desc "Build and upload directly to TestFlight on every push"
  lane :deploy_testflight do
    
    # 1. Standard CI initialization for headless keychain behavior
    setup_ci
    
    # 2. Fetch your pre-existing profiles from your private Git repo
    match(
      type: "appstore",
      readonly: true
    )
    
    # 4. Force slow cloud-runner stability variables
    ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] = "120"
    ENV["FASTLANE_XCODEBUILD_SETTINGS_RETRIES"] = "5"
    
    # 5. DYNAMIC OPTIONS PLIST CREATION
    # We build the packaging instructions manually so xcodebuild has no room to look at legacy settings.
    export_options = {
      method: "app-store-connect",
      signingStyle: "manual",
      teamID: "SU5Z39MX2P",
      provisioningProfiles: {
        "com.blaster.fpil" => "AppStoreFPIL2025"
      }
    }
    
    # 6. DIRECT COMPILATION ENGINE INVOKE
    # By running raw xcodebuild, we stamp the parameters globally across both steps.
    xcodebuild(
      workspace: "FPIL.xcworkspace",
      scheme: "FPIL",
      archive: true,
      archive_path: "./build/FPIL.xcarchive",
      export_archive: true,
      export_options: export_options,
      export_path: "./build",
      # This targets the identity parameter across ALL child execution blocks cleanly,
      # while removing signing constraints from underlying Firebase SPM bundles.
      xcargs: "CODE_SIGN_IDENTITY=\"Apple Distribution\" DEVELOPMENT_TEAM=\"SU5Z39MX2P\" PROVISIONING_PROFILE_SPECIFIER=\"AppStoreFPIL2025\" 'CODE_SIGNING_ALLOWED[sdk=iphoneos*][type=com.apple.product-type.bundle]'=NO"
    )

    # 7. Upload the generated binary straight into TestFlight
    upload_to_testflight(
      ipa: "./build/FPIL.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end